<div class="page-container flex flex-col items-center justify-center h-96">
  <h2 class="page-title">ターン結果</h2>
  
  <div class="flex justify-between items-center w-full px-10">
    <div class="text-center w-1/3">
      <p class="text-sm text-gray-500 mb-2">相手</p>
      <%# 相手の手を表示 %>
      <p data-room-target="opponentActionDisplay" class="text-3xl font-bold text-red-500"></p>
    </div>

    <div class="text-2xl font-bold w-1/3 text-center">VS</div>

    <div class="text-center w-1/3">
      <p class="text-sm text-gray-500 mb-2">自分</p>
      <%# 自分の手を表示 %>
      <p data-room-target="myActionDisplay" class="text-3xl font-bold text-blue-500"></p>
    </div>
  </div>

  <div class="mt-12 text-center h-16">
    <%# 結果を表示 %>
    <p
      data-room-target="resultMessageDisplay"
      class="text-2xl font-bold animate-bounce text-game-text-primary"
      >
    </p>
  </div>
</div>